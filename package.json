{
  "name": "obsidian-calendar",
  "productName": "Obsidian Calendar Editor",
  "version": "1.0.0",
  "description": "A desktop editor for Obsidian Full Calendar event notes.",
  "packageManager": "bun@1.2.15",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "start:system-frame": "OBSIDIAN_CALENDAR_SYSTEM_FRAME=1 electron-forge start",
    "start:x11": "OBSIDIAN_CALENDAR_SYSTEM_FRAME=1 OBSIDIAN_CALENDAR_OZONE_PLATFORM=x11 ELECTRON_OZONE_PLATFORM_HINT=x11 electron-forge start",
    "preview:browser": "vite --host 127.0.0.1",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx src src/main.ts src/preload.ts src/electron.d.ts forge.config.ts"
  },
  "keywords": [],
  "author": {
    "name": "GrajAP",
    "email": "adampisarczyk2006@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "electron": "42.0.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "~4.5.4",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
